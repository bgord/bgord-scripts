{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "boundaries": {
    "zones": [
      { "name": "src", "patterns": ["src/**"] },
      { "name": "modules", "patterns": ["modules/**"] },
      { "name": "infra", "patterns": ["infra/**"] },
      { "name": "app", "patterns": ["app/**"] },
      { "name": "tests", "patterns": ["tests/**"] }
    ],
    "rules": [
      { "from": "src", "allow": [] },
      { "from": "modules", "allow": [] },
      { "from": "infra", "allow": ["modules"] },
      { "from": "app", "allow": ["modules"] },
      { "from": "tests", "allow": ["src", "modules", "infra", "app"] }
    ]
  }
}
