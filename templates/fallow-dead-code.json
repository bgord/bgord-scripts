{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": ["bgord-scripts/*", "tests/fixtures/*"],
  "ignoreDependencies": [
    "@bgord/tools",
    "@bgord/bun",
    "@stryker-mutator/typescript-checker",
    "croner",
    "gzip-cli",
    "hono",
    "lightningcss-cli",
    "lockfile-lint",
    "nodemailer",
    "shellcheck",
    "valibot"
  ],
  "entry": ["index.ts", "app/**/*.ts", "modules/**/*.ts", "infra/**/*.ts"]
}
