{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": ["bgord-scripts/*", "tests/fixtures/*", "tests/_setup.ts"],
  "ignoreDependencies": [
    "@bgord/bun",
    "@bgord/design",
    "@bgord/tools",
    "@bgord/ui",
    "better-auth",
    "iconoir-react",
    "react",
    "better-sqlite3",
    "@better-auth/drizzle-adapter",
    "@fullhuman/postcss-purgecss",
    "@happy-dom/global-registrator",
    "@stryker-mutator/typescript-checker",
    "croner",
    "gzip-cli",
    "hono",
    "lightningcss-cli",
    "lockfile-lint",
    "nodemailer",
    "shellcheck",
    "valibot"
  ],
  "entry": ["index.ts", "app/**/*.ts", "modules/**/*.ts", "infra/**/*.ts", "scripts/**/*.ts"]
}
