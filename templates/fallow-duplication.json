{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "bgord-scripts/*",
    "tests/fixtures/*",
    "tests/_setup.ts",
    "tests/*.test.ts",
    "public/*",
    "output/*",
    "web/entry-client.tsx"
  ],
  "duplicates": {
    "enabled": true,
    "mode": "strict",
    "minLines": 15,
    "minTokens": 150,
    "minOccurrences": 3,
    "ignoreComments": true,
    "ignoreStringLiterals": true,
    "ignoreImports": true,
    "skipLocal": true
  }
}
