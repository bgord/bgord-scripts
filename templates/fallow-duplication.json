{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "bgord-scripts/",
    "tests/fixtures/",
    "dist/",
    "output/",
    "public/",
    "*.test.ts",
    "*.spec.ts"
  ],
  "duplicates": {
    "enabled": true,
    "mode": "mild",
    "minLines": 5,
    "minTokens": 50,
    "ignoreComments": true,
    "ignoreStringLiterals": false,
    "minOccurrences": 2,
    "threshold": 0.0,
    "ignore": [],
    "ignoreDefaults": true,
    "skipLocal": false,
    "crossLanguage": false,
    "ignoreImports": true
  }
}
